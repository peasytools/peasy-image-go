# peasy-image-go — Image resize, crop, convert (Go)
# Theme: Tokyo Night
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "TokyoNight"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-image-go — Image resize, crop, convert for Go"
Enter
Type "# peasyimage.com"
Enter
Sleep 500ms

# Run the demo
Type "go run ./examples/demo/"
Enter
Sleep 5s
